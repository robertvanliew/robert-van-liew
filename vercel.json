{
  "redirects": [
    { "source": "/tax-analyzer", "destination": "/smart-deductions-case-study", "permanent": true },
    { "source": "/jersey-club-radio", "destination": "/jersey-club-radio-case-study", "permanent": true },
    { "source": "/dmc-canada-26", "destination": "/dmc-dj-canada-case-study", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/Portfolio.html" },
    { "source": "/about", "destination": "/Portfolio.html" },
    { "source": "/work", "destination": "/Portfolio.html" },
    { "source": "/systems-craft", "destination": "/Portfolio.html" },
    { "source": "/contact", "destination": "/Portfolio.html" },
    { "source": "/smart-deductions-case-study", "destination": "/Portfolio.html" },
    { "source": "/jersey-club-radio-case-study", "destination": "/case-study-jersey-club.html" },
    { "source": "/dmc-dj-canada-case-study", "destination": "/case-study-dmc.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
